# Portal surface: which products and nav links to show, and which routes to block
#   full — default: internal + client surfaces (e.g. changelog) where configured
#   client — client-facing: hides internal-only links; blocks /changelog
#   internal — reserved for a future internal-only build (same as full for now)
NEXT_PUBLIC_PORTAL_AUDIENCE=full

# Session secret for /login (see .env or deployment env)
# PASSWORD=your-shared-password
# FORGE_AUTH_SECRET=openssl-rand-hex-32

# Assess product: Postgres (Neon / Supabase / Vercel Postgres). Copy to .env.local and run: npm run db:migrate
# Pooled (recommended) — or use POSTGRES_URL from the Neon/Vercel template instead of DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host-pooler.region.aws.neon.tech/neondb?sslmode=require
# POSTGRES_URL=...

# Assess product: OpenAI inference for offshore% / AI% defaults (Re-score every row,
# Fill blanks). When unset, the API silently falls back to the deterministic Versant
# heuristic in src/data/assess/seedAssessmentDefaults.ts — the program never breaks.
# OPENAI_API_KEY=sk-proj-...
# Global default when a feature-specific model below is unset. Use a smaller/cheaper slug here, then
# set heavier models per route in production.
# OPENAI_MODEL=gpt-4o-mini
#
# Per-feature model env (precedence: options.model in code, then the feature var, then OPENAI_MODEL, then
# the module default). In prod (e.g. Vercel) set the same OPENAI_API_KEY once; set each *_MODEL as needed.
# | Feature / code path            | Feature env (optional)           | Typical when unset   |
# |-------------------------------|----------------------------------|----------------------|
# | Re-score / Fill blanks (AI%)  | OPENAI_INFER_DEFAULTS_MODEL      | OPENAI_MODEL, mini   |
# | L4 activities (capability map)| OPENAI_GENERATE_L4_MODEL         | OPENAI_MODEL, mini   |
# | Curation of initiatives rows  | OPENAI_CURATE_INITIATIVES_MODEL  | OPENAI_MODEL, mini   |
# | Lazy full-Process (curate)    | OPENAI_CURATE_BRIEF_MODEL        | OPENAI_MODEL, gpt-5.5 |
#
# OPENAI_INFER_DEFAULTS_MODEL=
# OPENAI_GENERATE_L4_MODEL=
# OPENAI_CURATE_INITIATIVES_MODEL=
#
# Lazy full-Process brief route (`/api/assess/curate-brief`): defaults to gpt-5.5 + Responses API + reasoning
# (GPT-5 family); other features use Chat Completions.
# OPENAI_CURATE_BRIEF_MODEL=gpt-5.5
# OPENAI_CURATE_BRIEF_REASONING_EFFORT=medium
# Set to 1 to use Chat Completions for GPT-5 (e.g. debugging) — not recommended for reasoning quality.
# OPENAI_CURATE_BRIEF_USE_CHAT_COMPLETIONS=0
# OPENAI_CURATE_BRIEF_MAX_OUTPUT_TOKENS=16000
# CURATE_BRIEF_TIMEOUT_MS=120000
